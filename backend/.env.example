MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net"
MONGODB_DB_NAME="studyflow"
SESSION_SECRET_KEY="<generate-a-random-secret-key>"
GROQ_API_KEY="gsk_<your_groq_api_key>"
GOOGLE_CLIENT_ID="<your_google_client_id>"
GOOGLE_CLIENT_SECRET="<your_google_client_secret>"

# Optional: OpenAI Whisper for speech-to-text (falls back to Google STT if unset)
# OPENAI_API_KEY="sk-<your_openai_api_key>"

# Optional: Override frontend redirect URL (auto-detected from request if unset)
# FRONTEND_URL="http://localhost:3000"
